{
  "name": "open-mini",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "极简版 AI 编程助手 - 只支持 MiniMax Code Plan CN",
  "main": "src/index.ts",
  "bin": {
    "open-mini": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --outdir dist --target bun",
