    "zod": "^3.24.0",
    "minimatch": "^10.0.0",
    "chokidar": "^4.0.0",
    "fuzzysort": "^3.1.0",
    "@clack/prompts": "^1.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
